PORT=3333

# development usa SQLite automaticamente.
# production usa Postgres automaticamente e exige DATABASE_URL.
NODE_ENV=development

# SQLite dev
SQLITE_FILE=./data/app-max.sqlite

# Postgres prod
DATABASE_URL=postgres://user:password@localhost:5432/app_max
DATABASE_SSL=false

# Auth JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h

# Seed automatico do admin. Por padrao: true em dev e false em prod.
AUTH_SEED_ADMIN=true
AUTH_ADMIN_NAME=Admin App Max
AUTH_ADMIN_EMAIL=admin@appmax.local
AUTH_ADMIN_PASSWORD=admin123456
